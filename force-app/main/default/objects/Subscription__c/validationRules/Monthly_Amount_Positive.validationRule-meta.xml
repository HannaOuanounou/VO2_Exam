<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Monthly_Amount_Positive</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Monthly_Amount__c)),
    Monthly_Amount__c &lt;= 0
)</errorConditionFormula>
    <errorDisplayField>Monthly_Amount__c</errorDisplayField>
    <errorMessage>Monthly Amount must be greater than 0.</errorMessage>
</ValidationRule>
